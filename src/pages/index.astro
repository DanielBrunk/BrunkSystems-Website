---
import Layout from '../components/Layout.astro';
import { siteConfig } from '../config';
---

<Layout>
  <!-- ═══════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════ -->
  <section class="hero">
    <div class="hero__orb hero__orb--1"></div>
    <div class="hero__orb hero__orb--2"></div>
    <div class="hero__grid-pattern"></div>
    <div class="hero__content container">
      <div class="hero__badge">
        <span class="hero__badge-dot"></span>
        Bodensee · Konstanz · Singen · Rielasingen-Worblingen
      </div>
      <h1 class="hero__title">
        KI verstehen.<br />
        <span class="hero__title-accent">KI einsetzen.</span>
      </h1>
      <p class="hero__desc">
        Künstliche Intelligenz greifbar machen - von der Strategie bis zur fertigen Lösung.
      </p>
      <div class="hero__actions">
        <a href="#kontakt" class="btn btn-accent btn-xl">Projekt besprechen</a>
        <a href="#bereiche" class="btn btn-ghost btn-xl">Unsere Bereiche</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       LEISTUNGEN
       ═══════════════════════════════════════════ -->
  <section class="services" id="bereiche">
    <div class="container">
      <div>
        <p class="section-label">Bereiche</p>
        <h2 class="section-title">Vier Wege.<br />Ein Thema: KI.</h2>
        <p class="section-desc">
          Künstliche Intelligenz ist kein Feature - sie verändert, wie wir arbeiten, denken und entscheiden.
        </p>
      </div>

      <div class="services__grid">
        <div class="card fade-up">
          <div class="card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2a8 8 0 0 0-8 8c0 3.4 2.1 6.3 5 7.4V20a1 1 0 0 0 1 1h4a1 1 0 0 0 1-1v-2.6c2.9-1.1 5-4 5-7.4a8 8 0 0 0-8-8z" />
              <line x1="9" x2="15" y1="22" y2="22" />
            </svg>
          </div>
          <h3 class="card__title">KI-Beratung</h3>
          <p class="card__text">Persönliche Beratung für Unternehmen und Einzelpersonen. Wo macht KI Sinn? Wo nicht? Wir finden es gemeinsam heraus.</p>
          <div class="card__tags">
            <span class="tag tag--soft">1:1 Beratung</span>
            <span class="tag tag--soft">Strategie</span>
          </div>
        </div>

        <div class="card fade-up">
          <div class="card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
              <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
            </svg>
          </div>
          <h3 class="card__title">Vorträge</h3>
          <p class="card__text">KI greifbar machen - für Teams, Events und Konferenzen. Kein Hype, sondern Substanz mit klarer Sprache.</p>
          <div class="card__tags">
            <span class="tag tag--soft">Events</span>
            <span class="tag tag--soft">Keynotes</span>
          </div>
        </div>

        <div class="card fade-up">
          <div class="card__icon card__icon--accent">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10" />
              <path d="M12 6v6l4 2" />
            </svg>
          </div>
          <h3 class="card__title">KI-Mindset</h3>
          <p class="card__text">Unser eigener Ansatz, wie KI in Unternehmen wirklich ankommt. Nicht die Technik entscheidet - sondern die Denkweise.</p>
          <div class="card__tags">
            <span class="tag tag--soft">Methodik</span>
            <span class="tag tag--soft">Implementierung</span>
          </div>
        </div>

        <div class="card fade-up">
          <div class="card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect width="18" height="10" x="3" y="11" rx="2" />
              <circle cx="12" cy="5" r="2" />
              <path d="M12 7v4" />
              <line x1="8" x2="8" y1="16" y2="16" />
              <line x1="16" x2="16" y1="16" y2="16" />
            </svg>
          </div>
          <h3 class="card__title">KI-Systeme</h3>
          <p class="card__text">Individuelle Systeme mit KI als Kern. Nicht nachgerüstet - von Grund auf neu gedacht und gebaut.</p>
          <div class="card__tags">
            <span class="tag tag--soft">Entwicklung</span>
            <span class="tag tag--soft">Integration</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       STATS
       ═══════════════════════════════════════════ -->
  <section class="stats">
    <div class="stats__orb stats__orb--1"></div>
    <div class="stats__orb stats__orb--2"></div>
    <div class="container">
      <div class="stats__grid fade-up">
        <div class="stats__item">
          <span class="stats__number">Verstehen</span>
        </div>
        <div class="stats__divider"></div>
        <div class="stats__item">
          <span class="stats__number">Umsetzen</span>
        </div>
        <div class="stats__divider"></div>
        <div class="stats__item">
          <span class="stats__number">Profitieren</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       PROZESS
       ═══════════════════════════════════════════ -->
  <section class="process" id="prozess">
    <div class="container">
      <div>
        <p class="section-label">Wie wir arbeiten</p>
        <h2 class="section-title">Vom Problem<br />zur Lösung.</h2>
      </div>

      <div class="process__steps">
        <div class="process__step fade-up">
          <div class="process__number">01</div>
          <div class="process__content">
            <h3>Zuhören & Einordnen</h3>
            <p>Wo stehen Sie mit KI? Was haben Sie schon probiert? Wir verstehen erst Ihre Situation, bevor wir über Lösungen sprechen.</p>
          </div>
        </div>

        <div class="process__step fade-up">
          <div class="process__number">02</div>
          <div class="process__content">
            <h3>Mindset & Strategie</h3>
            <p>KI-Einsatz beginnt im Kopf, nicht im Code. Wir entwickeln gemeinsam ein Verständnis dafür, was KI für Sie konkret bedeutet.</p>
          </div>
        </div>

        <div class="process__step fade-up">
          <div class="process__number">03</div>
          <div class="process__content">
            <h3>Umsetzen & Befähigen</h3>
            <p>Ob Beratung, Vortrag oder KI-System - wir liefern nicht nur Ergebnisse, sondern Verständnis. Sie wissen danach, warum etwas funktioniert.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       PHILOSOPHIE
       ═══════════════════════════════════════════ -->
  <section class="philosophy">
    <div class="philosophy__orb philosophy__orb--1"></div>
    <div class="philosophy__orb philosophy__orb--2"></div>
    <div class="container">
      <div class="philosophy__inner fade-up">
        <blockquote class="philosophy__quote">
          <p>&bdquo;KI beginnt nicht im Code. KI beginnt im Kopf.&ldquo;</p>
          <cite>Daniel Brunk, BrunkSystems</cite>
        </blockquote>
        <div class="philosophy__values">
          <div class="philosophy__value">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20"><polyline points="20 6 9 17 4 12"/></svg>
            <span>KI ist Werkzeug, kein Selbstzweck</span>
          </div>
          <div class="philosophy__value">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Verständlichkeit vor Komplexität</span>
          </div>
          <div class="philosophy__value">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Erst das Mindset, dann die Technik</span>
          </div>
          <div class="philosophy__value">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Ehrliche Einschätzung statt Hype</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       ÜBER UNS
       ═══════════════════════════════════════════ -->
  <section class="about" id="ueber">
    <div class="container">
      <div class="about__inner">
        <div class="about__text fade-up">
          <p class="section-label">Über uns</p>
          <h2 class="section-title">Gärtnermeister<br />trifft Entwickler.</h2>
          <p class="about__desc">
            BrunkSystems ist ein Unternehmen von Daniel Brunk - Gärtnermeister und
            Entwickler am Bodensee. Was als interne Digitalisierung im eigenen
            GaLaBau-Betrieb begann, ist heute Dienstleistung für andere Unternehmen.
          </p>
          <p class="about__desc">
            Wir wissen, wie Handwerk tickt. Und wir wissen, was Technologie kann.
            Diese Kombination macht den Unterschied.
          </p>
          <div class="about__link">
            <span class="about__link-label">Schwesterfirma</span>
            <a href="https://brunk-garten.de" target="_blank" rel="noopener" class="btn btn-outline btn-md">
              Brunk Garten &rarr;
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       KONTAKT CTA
       ═══════════════════════════════════════════ -->
  <section class="cta" id="kontakt">
    <div class="cta__orb cta__orb--1"></div>
    <div class="cta__orb cta__orb--2"></div>
    <div class="container">
      <div class="cta__inner fade-up">
        <p class="section-label cta__label">Kontakt</p>
        <h2 class="cta__title">Lassen Sie uns über<br />Ihr Projekt sprechen.</h2>
        <p class="cta__desc">
          Kein Verkaufsgespräch. Kein Kleingedrucktes. Einfach ein Gespräch darüber,
          was Sie brauchen und wie wir helfen können.
        </p>
        <div class="cta__contact">
          <div class="cta__contact-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <a href="#" class="email" data-name="info" data-domain="brunksystems.de">
              <span class="email__protected" aria-label="info at brunksystems.de">ed.smetsysknurb@ofni</span>
            </a>
          </div>
          <div class="cta__contact-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <span>{siteConfig.address.zip} {siteConfig.address.city}</span>
          </div>
        </div>
        <a href={`mailto:${siteConfig.email}`} class="btn btn-accent btn-xl">
          E-Mail schreiben
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ═══════════════════════════════════════════
     HERO
     ═══════════════════════════════════════════ */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    background: var(--darker);
    overflow: hidden;
    padding: var(--space-3xl) 0;
  }

  .hero__orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
  }

  .hero__orb--1 {
    width: 500px;
    height: 400px;
    bottom: -100px;
    left: -100px;
    background: rgba(29,111,111,0.4);
  }

  .hero__orb--2 {
    width: 400px;
    height: 350px;
    top: -50px;
    right: -80px;
    background: rgba(153,195,59,0.12);
  }

  .hero__grid-pattern {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(153,195,59,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(153,195,59,0.04) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: radial-gradient(ellipse 70% 70% at 50% 50%, black, transparent);
  }

  .hero__content {
    position: relative;
    z-index: 1;
  }

  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: 8px 16px;
    border-radius: var(--radius-sm);
    background: rgba(153,195,59,0.1);
    color: var(--accent);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-bottom: var(--space-xl);
  }

  .hero__badge-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
  }

  .hero__title {
    font-size: clamp(48px, 8vw, 88px);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -3px;
    color: white;
    margin-bottom: var(--space-lg);
  }

  .hero__title-accent {
    background: linear-gradient(135deg, var(--primary-light), var(--accent));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero__desc {
    font-size: 18px;
    color: rgba(255,255,255,0.5);
    max-width: 50ch;
    line-height: 1.7;
    margin-bottom: var(--space-xl);
  }

  .hero__actions {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  /* ═══════════════════════════════════════════
     SERVICES
     ═══════════════════════════════════════════ */
  .services {
    padding: var(--space-3xl) 0;
    background: var(--white);
    position: relative;
  }

  .services::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 40% 60% at 10% 90%, rgba(29,111,111,0.06), transparent),
      radial-gradient(ellipse 50% 50% at 90% 10%, rgba(153,195,59,0.04), transparent);
    pointer-events: none;
  }

  .services__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
    margin-top: var(--space-2xl);
    position: relative;
  }

  .card__icon {
    width: 48px;
    height: 48px;
    padding: 12px;
    border-radius: var(--radius-md);
    background: rgba(29,111,111,0.08);
    color: var(--primary);
    margin-bottom: var(--space-lg);
    transition: all 0.3s var(--ease);
  }

  .card__icon--accent {
    background: rgba(153,195,59,0.12);
    color: #6a8a20;
  }

  .card:hover .card__icon {
    background: var(--primary);
    color: white;
    transform: scale(1.05);
  }

  .card:hover .card__icon--accent {
    background: var(--accent);
    color: var(--dark);
  }

  .card__title {
    font-size: 22px;
    font-weight: 700;
    margin-bottom: var(--space-sm);
    letter-spacing: -0.3px;
  }

  .card__text {
    font-size: 15px;
    color: var(--dark);
    opacity: 0.65;
    line-height: 1.7;
    margin-bottom: var(--space-lg);
  }

  .card__tags {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .tag {
    padding: 6px 14px;
    border-radius: var(--radius-sm);
    font-size: 12px;
    font-weight: 600;
    transition: all 0.2s var(--ease);
  }

  .tag:hover {
    transform: translateY(-1px);
  }

  .tag--soft {
    background: rgba(29,111,111,0.08);
    color: var(--primary);
  }

  /* ═══════════════════════════════════════════
     STATS
     ═══════════════════════════════════════════ */
  .stats {
    position: relative;
    padding: var(--space-2xl) 0;
    background: var(--dark);
    overflow: hidden;
  }

  .stats__orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
  }

  .stats__orb--1 {
    width: 300px;
    height: 250px;
    bottom: -80px;
    right: 10%;
    background: rgba(29,111,111,0.3);
  }

  .stats__orb--2 {
    width: 200px;
    height: 200px;
    top: -60px;
    left: 20%;
    background: rgba(153,195,59,0.1);
  }

  .stats__grid {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2xl);
    position: relative;
  }

  .stats__item {
    text-align: center;
  }

  .stats__number {
    display: block;
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 800;
    letter-spacing: -2px;
    color: white;
    line-height: 1;
  }

  .stats__label {
    display: block;
    font-size: 13px;
    font-weight: 500;
    color: rgba(255,255,255,0.4);
    margin-top: var(--space-sm);
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .stats__divider {
    width: 1px;
    height: 60px;
    background: rgba(255,255,255,0.1);
  }

  /* ═══════════════════════════════════════════
     PROCESS
     ═══════════════════════════════════════════ */
  .process {
    padding: var(--space-3xl) 0;
    background: var(--light);
    position: relative;
  }

  .process::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 50% 50% at 80% 20%, rgba(29,111,111,0.05), transparent),
      radial-gradient(ellipse 40% 60% at 20% 80%, rgba(153,195,59,0.03), transparent);
    pointer-events: none;
  }

  .process__steps {
    margin-top: var(--space-2xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
    max-width: 700px;
    position: relative;
  }

  .process__step {
    display: flex;
    gap: var(--space-xl);
    align-items: flex-start;
    padding: var(--space-xl);
    border-radius: var(--radius-xl);
    background: white;
    border: 1px solid rgba(212,207,196,0.5);
    box-shadow: var(--shadow-sm);
    transition: all 0.4s var(--ease);
  }

  .process__step:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .process__number {
    font-size: 40px;
    font-weight: 800;
    color: var(--primary);
    opacity: 0.2;
    line-height: 1;
    flex-shrink: 0;
    letter-spacing: -2px;
  }

  .process__content h3 {
    font-size: 20px;
    font-weight: 700;
    margin-bottom: var(--space-sm);
    color: var(--dark);
  }

  .process__content p {
    font-size: 15px;
    line-height: 1.7;
    color: var(--dark);
    opacity: 0.65;
  }

  /* ═══════════════════════════════════════════
     PHILOSOPHY
     ═══════════════════════════════════════════ */
  .philosophy {
    position: relative;
    padding: var(--space-3xl) 0;
    background: var(--darker);
    overflow: hidden;
  }

  .philosophy__orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
  }

  .philosophy__orb--1 {
    width: 400px;
    height: 350px;
    bottom: -100px;
    left: -50px;
    background: rgba(29,111,111,0.35);
    animation: float 24s ease-in-out infinite;
  }

  .philosophy__orb--2 {
    width: 300px;
    height: 250px;
    top: -80px;
    right: -40px;
    background: rgba(153,195,59,0.1);
    animation: float 22s ease-in-out infinite reverse;
  }

  .philosophy__inner {
    position: relative;
    max-width: 800px;
    margin-inline: auto;
    text-align: center;
  }

  .philosophy__quote {
    margin-bottom: var(--space-2xl);
  }

  .philosophy__quote p {
    font-size: clamp(24px, 3.5vw, 36px);
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.5px;
    color: white;
    max-width: none;
  }

  .philosophy__quote cite {
    display: block;
    margin-top: var(--space-lg);
    font-style: normal;
    font-size: 14px;
    color: rgba(255,255,255,0.4);
    font-weight: 500;
  }

  .philosophy__values {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
    text-align: left;
  }

  .philosophy__value {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-md) var(--space-lg);
    border-radius: var(--radius-md);
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.85);
    font-size: 15px;
    font-weight: 500;
    transition: all 0.3s var(--ease);
  }

  .philosophy__value:hover {
    background: rgba(255,255,255,0.12);
    color: white;
  }

  .philosophy__value svg {
    flex-shrink: 0;
    color: var(--accent);
  }

  /* ═══════════════════════════════════════════
     ABOUT
     ═══════════════════════════════════════════ */
  .about {
    padding: var(--space-3xl) 0;
    background: var(--white);
    position: relative;
  }

  .about::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 50% 60% at 90% 90%, rgba(29,111,111,0.05), transparent);
    pointer-events: none;
  }

  .about__inner {
    max-width: 700px;
    position: relative;
  }

  .about__desc {
    font-size: 16px;
    line-height: 1.8;
    color: var(--dark);
    opacity: 0.7;
    margin-bottom: var(--space-md);
  }

  .about__link {
